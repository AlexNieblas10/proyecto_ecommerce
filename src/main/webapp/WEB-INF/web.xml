<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>FashionHub Ecommerce</display-name>

    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <!-- ===== FILTROS ===== -->

    <filter>
        <filter-name>CorsFilter</filter-name>
        <filter-class>org.ecommerce.filter.CorsFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>CorsFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>org.ecommerce.filter.AuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/api/users/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/api/cart/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/api/orders/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/perfil</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/checkout</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/carrito</url-pattern>
    </filter-mapping>

    <filter>
        <filter-name>AdminFilter</filter-name>
        <filter-class>org.ecommerce.filter.AdminFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AdminFilter</filter-name>
        <url-pattern>/api/admin/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AdminFilter</filter-name>
        <url-pattern>/admin/*</url-pattern>
    </filter-mapping>

    <filter>
        <filter-name>OptionalAuthFilter</filter-name>
        <filter-class>org.ecommerce.filter.OptionalAuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>OptionalAuthFilter</filter-name>
        <url-pattern>/api/products/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>OptionalAuthFilter</filter-name>
        <url-pattern>/api/products</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>OptionalAuthFilter</filter-name>
        <url-pattern>/api/categories/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>OptionalAuthFilter</filter-name>
        <url-pattern>/api/categories</url-pattern>
    </filter-mapping>

    <servlet-mapping>
        <servlet-name>default</servlet-name>
        <url-pattern>/css/*</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>default</servlet-name>
        <url-pattern>/js/*</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>default</servlet-name>
        <url-pattern>/images/*</url-pattern>
    </servlet-mapping>

    <!-- ===== SERVLETS DE PÁGINA ===== -->

    <servlet>
        <servlet-name>IndexServlet</servlet-name>
        <servlet-class>org.ecommerce.servlet.page.IndexServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>IndexServlet</servlet-name>
        <url-pattern>/</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>StoreServlet</servlet-name>
        <servlet-class>org.ecommerce.servlet.page.StoreServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StoreServlet</servlet-name>
        <url-pattern>/tienda</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>CartPageServlet</servlet-name>
        <servlet-class>org.ecommerce.servlet.page.CartPageServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CartPageServlet</servlet-name>
        <url-pattern>/carrito</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>CheckoutPageServlet</servlet-name>
        <servlet-class>org.ecommerce.servlet.page.CheckoutPageServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CheckoutPageServlet</servlet-name>
        <url-pattern>/checkout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LoginPageServlet</servlet-name>
        <servlet-class>org.ecommerce.servlet.page.LoginPageServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginPageServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>RegisterPageServlet</servlet-name>
        <servlet-class>org.ecommerce.servlet.page.RegisterPageServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterPageServlet</servlet-name>
        <url-pattern>/registro</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ProfilePageServlet</servlet-name>
        <servlet-class>org.ecommerce.servlet.page.ProfilePageServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProfilePageServlet</servlet-name>
        <url-pattern>/perfil</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ProductDetailPageServlet</servlet-name>
        <servlet-class>org.ecommerce.servlet.page.ProductDetailPageServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProductDetailPageServlet</servlet-name>
        <url-pattern>/tienda/producto</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminPageServlet</servlet-name>
        <servlet-class>org.ecommerce.servlet.page.AdminPageServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminPageServlet</servlet-name>
        <url-pattern>/admin/*</url-pattern>
    </servlet-mapping>

    <!-- ===== SERVLETS API ===== -->

    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>org.ecommerce.servlet.auth.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/api/auth/register</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>org.ecommerce.servlet.auth.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/api/auth/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>org.ecommerce.servlet.auth.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/api/auth/logout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ProfileServlet</servlet-name>
        <servlet-class>org.ecommerce.servlet.user.ProfileServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProfileServlet</servlet-name>
        <url-pattern>/api/users/me</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminUserServlet</servlet-name>
        <servlet-class>org.ecommerce.servlet.user.AdminUserServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminUserServlet</servlet-name>
        <url-pattern>/api/admin/users/*</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ProductServlet</servlet-name>
        <servlet-class>org.ecommerce.servlet.product.ProductServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProductServlet</servlet-name>
        <url-pattern>/api/products</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ProductServlet</servlet-name>
        <url-pattern>/api/products/*</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>CategoryServlet</servlet-name>
        <servlet-class>org.ecommerce.servlet.product.CategoryServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CategoryServlet</servlet-name>
        <url-pattern>/api/categories</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>CategoryServlet</servlet-name>
        <url-pattern>/api/categories/*</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>CartServlet</servlet-name>
        <servlet-class>org.ecommerce.servlet.cart.CartServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CartServlet</servlet-name>
        <url-pattern>/api/cart</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>CartServlet</servlet-name>
        <url-pattern>/api/cart/*</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>OrderServlet</servlet-name>
        <servlet-class>org.ecommerce.servlet.order.OrderServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>OrderServlet</servlet-name>
        <url-pattern>/api/orders</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>OrderServlet</servlet-name>
        <url-pattern>/api/orders/*</url-pattern>
    </servlet-mapping>

    <!-- ===== PÁGINAS DE ERROR ===== -->

    <error-page>
        <error-code>404</error-code>
        <location>/WEB-INF/jsp/errors/404.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/WEB-INF/jsp/errors/500.jsp</location>
    </error-page>

</web-app>
